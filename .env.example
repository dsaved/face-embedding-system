# Face Vector Embedding System Environment Configuration

# Flask Configuration
FLASK_ENV=development
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production
LOG_LEVEL=INFO

# Database Configuration
DATABASE_URL=postgresql://face_user:face_password@localhost:5432/face_db
# Alternative: DATABASE_URL=sqlite:///face_db.sqlite

# Redis Configuration (for caching and rate limiting)
REDIS_URL=redis://localhost:6379/0

# Face Processing Configuration
FACE_DETECTION_MODEL=opencv_dnn  # opencv_dnn, mtcnn
FACE_ENCODING_MODEL=facenet      # facenet, face_recognition
FACE_EMBEDDING_SIZE=512          # 128 or 512
MIN_FACE_SIZE=50
FACE_CONFIDENCE_THRESHOLD=0.5
SIMILARITY_THRESHOLD=0.6

# File Upload Settings
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216  # 16MB
MAX_FILE_SIZE=10485760       # 10MB

# Vector Database Settings
USE_FAISS_INDEX=True
FAISS_INDEX_PATH=data/face_index.faiss

# Cache Settings
CACHE_EMBEDDINGS=True
EMBEDDING_CACHE_TTL=3600

# Security Settings
API_KEY_REQUIRED=True
API_KEYS=sk-face123abc,sk-face456def,sk-face789ghi

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# File Security
SCAN_UPLOADS=True

# CORS Settings
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Audit Logging
AUDIT_LOG_ENABLED=True
AUDIT_LOG_FILE=logs/audit.log

# Security Headers
SECURITY_HEADERS_ENABLED=True
MIN_FACE_SIZE=50                 # minimum face size in pixels
FACE_CONFIDENCE_THRESHOLD=0.5    # face detection confidence threshold
SIMILARITY_THRESHOLD=0.6         # face similarity threshold

# File Upload Settings
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216      # 16MB

# Vector Database Settings
USE_FAISS_INDEX=True
FAISS_INDEX_PATH=data/face_index.faiss

# Redis Cache Settings
CACHE_EMBEDDINGS=True
EMBEDDING_CACHE_TTL=3600         # 1 hour in seconds

# Security Settings (Production)
# SECRET_KEY=your-very-secure-secret-key-for-production
# DATABASE_URL=postgresql://secure_user:secure_password@localhost:5432/face_db_prod
# DEBUG=False
# FLASK_ENV=production
